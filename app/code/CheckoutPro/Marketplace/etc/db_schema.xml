<?xml version="1.0"?>
<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/schema.xsd">
    <table name="checkoutpro_marketplace_vendor" resource="default" engine="innodb" comment="Marketplace Vendors">
        <column xsi:type="int" name="vendor_id" identity="true" unsigned="true" nullable="false" comment="Vendor ID"/>
        <column xsi:type="int" name="customer_id" unsigned="true" nullable="false" comment="Customer ID"/>
        <column xsi:type="varchar" name="shop_name" nullable="false" length="255" comment="Shop Name"/>
        <column xsi:type="varchar" name="status" nullable="false" length="32" default="pending" comment="Status"/>
        <column xsi:type="decimal" name="commission_rate" nullable="true" scale="4" precision="12" comment="Vendor Commission Rate"/>
        <column xsi:type="text" name="custom_fields" nullable="true" comment="Registration Custom Fields"/>
        <column xsi:type="timestamp" name="approved_at" nullable="true" comment="Approved At"/>
        <column xsi:type="timestamp" name="created_at" nullable="false" default="CURRENT_TIMESTAMP" comment="Created At"/>
        <column xsi:type="timestamp" name="updated_at" nullable="false" default="CURRENT_TIMESTAMP" on_update="true" comment="Updated At"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="vendor_id"/>
        </constraint>
        <constraint xsi:type="unique" referenceId="CHECKOUTPRO_MARKETPLACE_VENDOR_CUSTOMER_ID_UNQ">
            <column name="customer_id"/>
        </constraint>
        <constraint xsi:type="foreign" referenceId="CHECKOUTPRO_MARKETPLACE_VENDOR_CUSTOMER_ID_CUST_ENTITY"
                    table="checkoutpro_marketplace_vendor" column="customer_id"
                    referenceTable="customer_entity" referenceColumn="entity_id" onDelete="CASCADE"/>
        <index referenceId="CHECKOUTPRO_MARKETPLACE_VENDOR_STATUS_IDX" indexType="btree">
            <column name="status"/>
        </index>
    </table>

    <table name="checkoutpro_marketplace_product" resource="default" engine="innodb" comment="Marketplace Product Mapping">
        <column xsi:type="int" name="entity_id" identity="true" unsigned="true" nullable="false" comment="ID"/>
        <column xsi:type="int" name="vendor_id" unsigned="true" nullable="false" comment="Vendor ID"/>
        <column xsi:type="int" name="product_id" unsigned="true" nullable="false" comment="Product ID"/>
        <column xsi:type="text" name="custom_fields" nullable="true" comment="Product Custom Fields"/>
        <column xsi:type="decimal" name="shipping_rate" nullable="true" scale="4" precision="12" comment="Vendor Shipping Rate"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="entity_id"/>
        </constraint>
        <constraint xsi:type="foreign" referenceId="CHECKOUTPRO_MARKETPLACE_PRODUCT_VENDOR_ID_VENDOR_VENDOR_ID"
                    table="checkoutpro_marketplace_product" column="vendor_id"
                    referenceTable="checkoutpro_marketplace_vendor" referenceColumn="vendor_id" onDelete="CASCADE"/>
        <constraint xsi:type="foreign" referenceId="CHECKOUTPRO_MARKETPLACE_PRODUCT_PRODUCT_ID_CAT_PRODUCT_ENTITY_ENTITY_ID"
                    table="checkoutpro_marketplace_product" column="product_id"
                    referenceTable="catalog_product_entity" referenceColumn="entity_id" onDelete="CASCADE"/>
        <constraint xsi:type="unique" referenceId="CHECKOUTPRO_MARKETPLACE_PRODUCT_VENDOR_PRODUCT_UNQ">
            <column name="vendor_id"/>
            <column name="product_id"/>
        </constraint>
    </table>

    <table name="checkoutpro_marketplace_payout" resource="default" engine="innodb" comment="Marketplace Payouts">
        <column xsi:type="int" name="payout_id" identity="true" unsigned="true" nullable="false" comment="Payout ID"/>
        <column xsi:type="int" name="vendor_id" unsigned="true" nullable="false" comment="Vendor ID"/>
        <column xsi:type="decimal" name="amount" nullable="false" scale="4" precision="12" comment="Amount"/>
        <column xsi:type="varchar" name="status" nullable="false" length="32" default="requested" comment="Status"/>
        <column xsi:type="varchar" name="transaction_reference" nullable="true" length="255" comment="Transaction Reference"/>
        <column xsi:type="text" name="notes" nullable="true" comment="Payout Notes"/>
        <column xsi:type="timestamp" name="approved_at" nullable="true" comment="Approved At"/>
        <column xsi:type="timestamp" name="created_at" nullable="false" default="CURRENT_TIMESTAMP" comment="Created At"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="payout_id"/>
        </constraint>
        <constraint xsi:type="foreign" referenceId="CHECKOUTPRO_MARKETPLACE_PAYOUT_VENDOR_ID_VENDOR_VENDOR_ID"
                    table="checkoutpro_marketplace_payout" column="vendor_id"
                    referenceTable="checkoutpro_marketplace_vendor" referenceColumn="vendor_id" onDelete="CASCADE"/>
        <index referenceId="CHECKOUTPRO_MARKETPLACE_PAYOUT_VENDOR_ID_STATUS" indexType="btree">
            <column name="vendor_id"/>
            <column name="status"/>
        </index>
    </table>

    <table name="checkoutpro_marketplace_review" resource="default" engine="innodb" comment="Marketplace Vendor Reviews">
        <column xsi:type="int" name="review_id" identity="true" unsigned="true" nullable="false" comment="Review ID"/>
        <column xsi:type="int" name="vendor_id" unsigned="true" nullable="false" comment="Vendor ID"/>
        <column xsi:type="int" name="customer_id" unsigned="true" nullable="false" comment="Customer ID"/>
        <column xsi:type="smallint" name="rating" unsigned="true" nullable="false" default="5" comment="Rating"/>
        <column xsi:type="text" name="comment" nullable="true" comment="Comment"/>
        <column xsi:type="timestamp" name="created_at" nullable="false" default="CURRENT_TIMESTAMP" comment="Created At"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="review_id"/>
        </constraint>
        <constraint xsi:type="foreign" referenceId="CHECKOUTPRO_MARKETPLACE_REVIEW_VENDOR_ID_VENDOR_VENDOR_ID"
                    table="checkoutpro_marketplace_review" column="vendor_id"
                    referenceTable="checkoutpro_marketplace_vendor" referenceColumn="vendor_id" onDelete="CASCADE"/>
        <constraint xsi:type="foreign" referenceId="CHECKOUTPRO_MARKETPLACE_REVIEW_CUSTOMER_ID_CUSTOMER_ENTITY_ENTITY_ID"
                    table="checkoutpro_marketplace_review" column="customer_id"
                    referenceTable="customer_entity" referenceColumn="entity_id" onDelete="CASCADE"/>
    </table>
</schema>
