<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Event/etc/events.xsd">
    <event name="customer_register_success">
        <observer name="checkoutpro_marketplace_vendor_registration" instance="CheckoutPro\Marketplace\Observer\RegisterVendorFromCustomer"/>
    </event>
    <event name="catalog_product_save_after">
        <observer name="checkoutpro_marketplace_product_save" instance="CheckoutPro\Marketplace\Observer\MapVendorProduct"/>
    </event>
</config>
